<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/customerFormFragment">

    <fragment
        android:id="@+id/customerFormFragment"
        android:name="com.example.twoscreen.ui.fragments.CustomerFormFragment"
        android:label="Customer Form"
        tools:layout="@layout/fragment_customer_form">
        <action
            android:id="@+id/action_form_to_success"
            app:destination="@id/successFragment"
            app:popUpTo="@id/customerFormFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/successFragment"
        android:name="com.example.twoscreen.ui.fragments.SuccessFragment"
        android:label="Success"
        tools:layout="@layout/fragment_success">

        <!-- Safe Args arguments -->
        <argument
            android:name="name"
            app:argType="string" />
        <argument
            android:name="email"
            app:argType="string" />
        <argument
            android:name="phone"
            app:argType="string" />
        <argument
            android:name="city"
            app:argType="string" />

    </fragment>

</navigation>